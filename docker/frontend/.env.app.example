# ==================== APP-SERVER (app.servecta.local) ====================
# Kopiere zu .env.app und passe an.
# Verwendung: docker compose -f docker-compose.app.yml --env-file .env.app up -d
#
# Voraussetzung: api.servecta.local muss laufen (Backend)

STACK_NAME=gastropilot-app
IMAGE_TAG=latest

BASE_URL=https://app.servecta.local
# API-Base-URL fuer Frontend (Same-Origin via nginx-Proxy)
NEXT_PUBLIC_API_BASE_URL=https://app.servecta.local

AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
API_PREFIX=/v1
