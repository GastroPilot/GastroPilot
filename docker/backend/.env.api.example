# ==================== API-SERVER (api.servecta.local) ====================
# Kopiere zu .env.api und passe an.
# Verwendung: docker compose -f docker-compose.api.yml --env-file .env.api up -d
#
# Voraussetzung: db-01.servecta.local muss laufen (Postgres, Redis)

STACK_NAME=gastropilot-api
IMAGE_TAG=latest

# Datenbank (db-01.servecta.local)
POSTGRES_DB=gastropilot
POSTGRES_USER=gastropilot
POSTGRES_PASSWORD=CHANGE_ME_MUSS_MIT_DB_SERVER_UEBEREINSTIMMEN

# Redis (db-01.servecta.local)
REDIS_PASSWORD=CHANGE_ME_MUSS_MIT_DB_SERVER_UEBEREINSTIMMEN

# Optional: Vollstaendige URLs (wenn andere Hosts)
# DATABASE_URL=postgresql+asyncpg://user:pass@db-01.servecta.local:5432/gastropilot?sslmode=disable
# REDIS_URL=redis://:pass@db-01.servecta.local:6379/0

JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ISSUER=gastropilot
JWT_AUDIENCE=gastropilot-api

CORS_ORIGINS=https://app.servecta.local
ALLOWED_HOSTS=app.servecta.local,api.servecta.local

BASE_URL=https://app.servecta.local

# SMTP, Mothership, OpenAI, Twilio, SumUp, Sentry (optional)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@gastropilot.de
SMTP_FROM_NAME=GastroPilot
