# ==================== SERVER ENVIRONMENT (GHCR + WATCHTOWER) ====================
# Kopiere diese Datei zu .env.server und passe ALLE Werte an!
# Verwendung: docker compose -f docker-compose.server.yml --env-file .env.server up -d

# ==================== STACK ====================
# Name des Docker-Stacks (beeinflusst Container-Namen)
# "gastropilot" fuer Produktion, "gastropilot-staging" / "gastropilot-demo" / "gastropilot-test"
STACK_NAME=gastropilot

# ==================== DOCKER HUB IMAGE-KONFIGURATION ====================
# Image-Tag: "latest" fuer Production, "staging" / "demo" / "test"
IMAGE_TAG=latest

# ==================== POSTGRESQL ====================
POSTGRES_DB=gastropilot
POSTGRES_USER=gastropilot
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# ==================== BACKEND ====================
# DATABASE_URL wird automatisch aus den PostgreSQL-Variablen zusammengesetzt.
# Nur setzen, wenn eine externe Datenbank (z.B. Neon) verwendet wird:
# DATABASE_URL=postgresql+asyncpg://user:password@your-neon-host.neon.tech:5432/dbname
# DATABASE_TYPE=neon

# SSL-Verifizierung fuer Datenbankverbindung
# "false" fuer lokale PostgreSQL (kein SSL), "true" fuer externe DBs (z.B. Neon)
DATABASE_SSL_VERIFY=false

JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ISSUER=gastropilot
JWT_AUDIENCE=gastropilot-api
JWT_LEEWAY_SECONDS=10

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password Hashing
BCRYPT_ROUNDS=12

# CORS & Security
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOW_CREDENTIALS=true
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# Rate Limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_ATTEMPTS=10

# Monitoring
HEALTH_CHECK_ENABLED=true

# Redis
# REDIS_URL wird automatisch aus REDIS_PASSWORD zusammengesetzt, wenn nicht explizit gesetzt.
# Standard: redis://:REDIS_PASSWORD@redis:6379/0
# Nur setzen, wenn ein externer Redis-Server verwendet wird:
# REDIS_URL=redis://:password@your-redis-host:6379/0
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# ==================== E-MAIL (SMTP) ====================
# SMTP-Server fuer E-Mail-Versand (Kampagnen, Benachrichtigungen, Tracking)
# Ohne gueltige SMTP-Daten werden E-Mails nur geloggt, nicht gesendet.
SMTP_HOST=mail.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=GastroPilot

# ==================== MOTHERSHIP (LIZENZVERWALTUNG) ====================
# URL und API-Key zum Mothership-Server (Kunden- und Lizenzverwaltung)
# Nur setzen, wenn ein Mothership-Server betrieben wird.
#
# Test-Environment:
# MOTHERSHIP_API_URL=https://test.mothership.yourdomain.com
# MOTHERSHIP_API_KEY=CHANGE_ME_TEST_API_KEY
#
# Produktion:
# MOTHERSHIP_API_URL=https://mothership.yourdomain.com
# MOTHERSHIP_API_KEY=CHANGE_ME_PRODUCTION_API_KEY

# ==================== OPENAI ====================
# API-Key fuer OpenAI (GPT, Embeddings, etc.)
# Nur setzen, wenn KI-Features genutzt werden.
# OPENAI_API_KEY=sk-...

# ==================== TWILIO (SMS / TELEFONIE) ====================
# Twilio-Zugangsdaten fuer SMS-Versand und Telefonie-Features.
# Nur setzen, wenn Twilio genutzt wird.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+49...

# ==================== SUMUP (ZAHLUNGEN) ====================
# SumUp-Zugangsdaten fuer Zahlungsabwicklung.
# Nur setzen, wenn SumUp-Integration genutzt wird.
# SUMUP_API_KEY=...
# SUMUP_MERCHANT_CODE=...
# SUMUP_CALLBACK_URL=https://yourdomain.com/v1/payments/callback

# ==================== SENTRY (ERROR TRACKING) ====================
# Sentry DSN fuer Error-Tracking und Performance-Monitoring.
# Nur setzen, wenn Sentry genutzt wird.
# SENTRY_DSN=https://...@sentry.io/...

# ==================== FRONTEND ====================
BASE_URL=https://yourdomain.com
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
API_PREFIX=/v1

# ==================== WATCHTOWER / DOCKER HUB AUTH ====================
# Damit Watchtower neue Images von Docker Hub ziehen kann,
# muss Docker auf dem Server eingeloggt sein:
#   docker login -u DOCKERHUB_USER -p DOCKERHUB_TOKEN
#
# Watchtower nutzt automatisch ~/.docker/config.json.

# ==================== WICHTIGE HINWEISE ====================
# 1. ALLE "CHANGE_ME" Werte MUESSEN geaendert werden!
# 2. Secrets generieren:
#    - JWT_SECRET: openssl rand -hex 32
#    - AUTH_SECRET: openssl rand -base64 32
#    - POSTGRES_PASSWORD: openssl rand -base64 32
#    - REDIS_PASSWORD: openssl rand -base64 32
# 3. Fuer externe DB (Neon): DATABASE_URL und DATABASE_TYPE setzen
# 4. CORS_ORIGINS und ALLOWED_HOSTS auf echte Domain(s) setzen
# 5. SSL-Zertifikate werden vom gemeinsamen Proxy verwaltet (../proxy/ssl/)
# 6. GHCR_OWNER muss lowercase sein (GitHub Username/Org)
# 7. NIEMALS diese .env.server Datei committen!
