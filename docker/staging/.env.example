# ==================== STAGE-SERVER (Single-Server Setup) ====================
# Kopiere zu .env und passe an.
# Verwendung: docker compose -f docker-compose.yml --env-file .env up -d
#
# Frontend: stage.gpilot.org | Backend: stage-api.gpilot.app


# ======= FRONTEND =======
STACK_NAME=gastropilot-staging
IMAGE_TAG=staging

BASE_URL=https://stage.gpilot.org
# API-Base-URL fuer Frontend (Same-Origin via nginx-Proxy)
NEXT_PUBLIC_API_BASE_URL=https://stage-api.gpilot.app

AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
API_PREFIX=/v1

# ======= BACKEND =======
# Datenbank
POSTGRES_DB=gastropilot_staging
POSTGRES_USER=gastropilot_staging
POSTGRES_PASSWORD=CHANGE_ME_MUSS_MIT_DB_SERVER_UEBEREINSTIMMEN

# Redis
REDIS_PASSWORD=CHANGE_ME_MUSS_MIT_DB_SERVER_UEBEREINSTIMMEN

JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ISSUER=gastropilot_staging
JWT_AUDIENCE=gastropilot_staging-api

CORS_ORIGINS=https://stage.gpilot.org
ALLOWED_HOSTS=stage.gpilot.org,stage-api.gpilot.app

